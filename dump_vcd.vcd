$scope module testbench_top $end
$var reg       1 !    clk $end
$var reg       1 "    reset $end

$scope module in $end
$var wire      1 #    clk  $end
$var wire      1 $    reset  $end
$var reg       8 %    data_in [7:0] $end
$var reg       8 &    data_out [7:0] $end
$var reg       1 '    empty $end
$var reg       1 (    full $end
$var reg       1 )    rd $end
$var reg       1 *    wr $end

$scope clocking driver_cb $end
$var reg       1 +    wr $end
$var reg       1 ,    rd $end
$var reg       8 -    data_in [7:0] $end
$upscope $end


$scope clocking monitor_cb $end
$var reg       1 .    wr $end
$var reg       1 /    rd $end
$var reg       8 0    data_in [7:0] $end
$var reg       8 1    data_out [7:0] $end
$var reg       1 2    empty $end
$var reg       1 3    full $end
$upscope $end

$upscope $end


$scope module dut $end
$var parameter 32 4    DATA_WIDTH $end
$var parameter 32 5    DEPTH $end
$var wire      1 #    clk  $end
$var wire      1 $    rst  $end
$var wire      1 6    wr_en  $end
$var wire      1 7    rd_en  $end
$var wire      8 8    wdata [7:0] $end
$var reg       8 9    rdata [7:0] $end
$var reg       1 :    full $end
$var reg       1 ;    empty $end
$var parameter 32 <    ADDR_WIDTH $end
$var reg       8 =    mem[0] [7:0] $end
$var reg       8 >    mem[1] [7:0] $end
$var reg       8 ?    mem[2] [7:0] $end
$var reg       8 @    mem[3] [7:0] $end
$var reg       8 A    mem[4] [7:0] $end
